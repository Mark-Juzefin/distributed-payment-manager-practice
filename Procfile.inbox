api: set -a && source env/common.env && source env/endpoints.host.env && source env/api.env && set +a && PORT=${API_PORT} WEBHOOK_MODE=kafka go run ./services/api/cmd
ingest: set -a && source env/common.env && source env/endpoints.host.env && source env/ingest.env && set +a && PORT=${INGEST_PORT} WEBHOOK_MODE=inbox go run ./services/ingest/cmd
cdc: set -a && source env/common.env && source env/endpoints.host.env && source env/cdc.env && set +a && go run ./services/cdc/cmd
analytics: set -a && source env/common.env && source env/endpoints.host.env && source env/analytics.env && set +a && go run ./services/analytics/cmd
