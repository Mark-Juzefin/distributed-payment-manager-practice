paymanager: set -a && source env/common.env && source env/endpoints.minimal.env && source env/paymanager.env && set +a && PORT=${API_PORT} WEBHOOK_MODE=http go run ./services/paymanager/cmd
ingest: set -a && source env/common.env && source env/endpoints.minimal.env && source env/ingest.env && set +a && PORT=${INGEST_PORT} WEBHOOK_MODE=http go run ./services/ingest/cmd
silvergate: set -a && source env/common.env && source env/endpoints.minimal.env && source env/silvergate.env && set +a && PORT=${SILVERGATE_PORT} go run ./services/silvergate/cmd
