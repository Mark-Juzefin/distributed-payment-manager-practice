# Minimal Endpoints (standalone PostgreSQL, no HAProxy/Patroni)
# Used with docker-compose.minimal.yaml

PG_URL=postgres://postgres:secret@localhost:5440/payments?sslmode=disable
# No PG_REPLICA_URL — single node, no read replica
KAFKA_BROKERS=localhost:9092
OPENSEARCH_URLS=http://localhost:9200
SILVERGATE_BASE_URL=http://localhost:3002
SILVERGATE_PG_URL=postgres://postgres:secret@localhost:5450/silvergate?sslmode=disable
WEBHOOK_CALLBACK_URL=http://localhost:3001/webhooks/silvergate
API_BASE_URL=http://localhost:3000
INGEST_PG_URL=postgres://postgres:secret@localhost:5440/ingest?sslmode=disable
